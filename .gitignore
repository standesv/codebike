# Node.js .gitignore

# Logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/Jest
coverage/

# Dependency directories
node_modules/
jspm_packages/

# Build output
dist/
build/

# OS-specific files
.DS_Store
Thumbs.db

# Editor/IDE specific
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment variables
.env
.env.test